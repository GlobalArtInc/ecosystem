{
  "name": "@globalart/nestjs-unit-of-work",
  "description": "Transactional integration for NestJS",
  "version": "4.0.2",
  "type": "module",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GlobalArtInc/ecosystem.git#main",
    "directory": "packages/nestjs-unit-of-work"
  },
  "license": "MIT",
  "author": "GlobalArt, Inc",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nestjs",
    "unit-of-work"
  ],
  "scripts": {
    "format": "prettier --write \"**/*.ts\"",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@globalart/ddd": "workspace:*",
    "@globalart/text-utils": "workspace:*",
    "rxjs": "^7.8.2",
    "typeorm": "^1.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/microservices": "^10.0.0 || ^11.0.0",
    "@nestjs/typeorm": "^10.0.0 || ^11.0.0",
    "typeorm": "^0.3.0 || ^1.0.0"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "tsdown": "0.22.2",
    "typescript": "^6.0.3"
  }
}
