{
  "name": "@globalart/nestjs-daemon",
  "version": "4.0.3",
  "description": "A daemon modules for NestJS",
  "author": {
    "name": "GlobalArt, Inc"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": "./dist/index.mjs",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GlobalArtInc/ecosystem.git#main",
    "directory": "packages/nestjs-daemon"
  },
  "keywords": [
    "nestjs",
    "daemon"
  ],
  "scripts": {
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest --runInBand --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "coveralls": "yarn run test:cov --coverageReporters=text-lcov | coveralls",
    "build": "rm -rf ./dist && tsdown",
    "build:watch": "tsdown --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@globalart/nestjs-redis": "4.0.3",
    "ioredis": "^5.11.1",
    "nestjs-cls": "6.2.1",
    "rxjs": "^7.8.1"
  },
  "peerDependencies": {
    "@nestjs/cache-manager": "^2.0.0 || ^3.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/microservices": "^10.0.0 || ^11.0.0",
    "@nestjs/platform-socket.io": "^10.0.0 || ^11.0.0",
    "@nestjs/terminus": "^0.2.0 || ^10.0.0 || ^11.0.0",
    "@nestjs/throttler": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "reflect-metadata": "^0.2.2",
    "tsdown": "0.22.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
