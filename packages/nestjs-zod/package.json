{
  "name": "@globalart/nestjs-zod",
  "description": "All NestJS + Zod utilities you need",
  "version": "4.0.6",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GlobalArtInc/ecosystem.git#main",
    "directory": "packages/nestjs-zod"
  },
  "sideEffects": false,
  "license": "MIT",
  "author": "GlobalArt, Inc",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest --runInBand --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "coveralls": "yarn run test:cov --coverageReporters=text-lcov | coveralls",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@golevelup/ts-jest": "^3.0.0",
    "@types/express": "5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/merge-deep": "3.0.3",
    "@types/node": "26.1.1",
    "@types/supertest": "^7.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "0.15.1",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "eslint-kit": "^11.39.0",
    "express": "5.2.1",
    "jest": "^30.4.2",
    "lodash": "^4.18.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "tsdown": "0.22.4",
    "typescript": "^7.0.2",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/swagger": "^7.4.2 || ^8.0.0 || ^11.0.0",
    "rxjs": "^7.0.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/swagger": {
      "optional": true
    }
  },
  "dependencies": {
    "deepmerge": "^4.3.1"
  }
}
