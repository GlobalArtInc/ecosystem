{
  "name": "@globalart/oxide",
  "version": "4.0.5",
  "author": {
    "name": "GlobalArt, Inc"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest --runInBand --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "coveralls": "yarn run test:cov --coverageReporters=text-lcov | coveralls",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "oxide",
    "rust"
  ],
  "description": "A simple toolkit for building scalable and maintainable applications",
  "devDependencies": {
    "@types/node": "26.1.0",
    "prettier": "3.9.4",
    "tsdown": "0.22.3",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
