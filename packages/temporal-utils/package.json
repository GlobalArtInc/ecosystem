{
  "name": "@globalart/temporal-utils",
  "description": "Temporal utilities",
  "version": "4.0.7",
  "type": "module",
  "private": false,
  "main": "dist/index.cjs",
  "module": "dist/index.cjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GlobalArtInc/ecosystem.git#main",
    "directory": "packages/temporal-utils"
  },
  "license": "MIT",
  "author": "GlobalArt, Inc",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "temporal"
  ],
  "scripts": {
    "format": "prettier --write \"**/*.ts\"",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@temporalio/activity": "^1.17.2",
    "@temporalio/client": "^1.17.2",
    "@temporalio/common": "^1.17.2",
    "@temporalio/worker": "^1.17.2",
    "@temporalio/workflow": "^1.17.2",
    "croner": "^10.0.1",
    "date-fns": "^4.4.0",
    "lodash": "^4.18.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsdown": "0.22.9",
    "typescript": "^7.0.2"
  }
}
