{
  "name": "@globalart/nestjs-temporal",
  "description": "Temporal integration for NestJS",
  "version": "4.0.4",
  "type": "module",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GlobalArtInc/ecosystem.git#main",
    "directory": "packages/nestjs-temporal"
  },
  "license": "MIT",
  "author": "GlobalArt, Inc",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nestjs",
    "temporal"
  ],
  "scripts": {
    "format": "prettier --write \"**/*.ts\"",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@temporalio/activity": "^1.17.2",
    "@temporalio/client": "^1.17.2",
    "@temporalio/common": "^1.17.2",
    "@temporalio/worker": "^1.17.2",
    "@temporalio/workflow": "^1.17.2",
    "lodash": "^4.18.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "reflect-metadata": "^0.2.2",
    "tsdown": "0.22.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0"
  }
}
