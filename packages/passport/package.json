{
  "name": "@globalart/passport",
  "version": "4.0.6",
  "author": {
    "name": "GlobalArt, Inc"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest --runInBand --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "coveralls": "yarn run test:cov --coverageReporters=text-lcov | coveralls",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openid-connect",
    "oauth2",
    "authentication",
    "globalart"
  ],
  "description": "OpenID Connect strategy for GlobalArt SSO integration",
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "26.1.0",
    "@types/passport": "^1.0.17",
    "prettier": "3.9.4",
    "ts-node": "^10.9.2",
    "tsdown": "0.22.4",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "express": "5.2.1",
    "node-fetch": "^3.3.2",
    "openid-connect": "^1.2.4",
    "passport": "^0.7.0",
    "url": "0.11.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
