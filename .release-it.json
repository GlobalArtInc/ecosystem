{
  "$schema": "https://unpkg.com/release-it@19/schema/release-it.json",
  "git": {
    "commitMessage": "release v${version}",
    "tagName": "v${version}",
    "tag": true,
    "requireCleanWorkingDir": true
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": "node scripts/sync-versions.mjs",
    "before:release": "pnpm build",
    "before:git:commit": "node scripts/publish-packages.mjs"
  }
}
